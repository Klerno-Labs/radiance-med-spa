# Radiance Med Spa Environment Variables
# Copy this file to .env.local and fill in the values

# Email Service (e.g., Resend for contact forms)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Analytics Tracking ID (e.g., Google Analytics 4)
# G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=